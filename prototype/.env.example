# SAOL — Система автоматизированной оценки ликвидности
# Скопируй в .env и заполни значения

# Какой провайдер аналитики: wb_public | mock
SAOL_ANALYTICS_PROVIDER=wb_public

# Какой провайдер визуального поиска: wb_photo | mock | http
# wb_photo — реальный WB visual search (search-by-photo.wb.ru/uploadsearch).
# mock — детерминированная заглушка для офлайн-тестов и dev.
# http — кастомный URL (например, MPStats), см. SAOL_VISUAL_SEARCH_URL.
SAOL_VISUAL_SEARCH_PROVIDER=wb_photo

# Endpoint для http-провайдера (опционально).
SAOL_VISUAL_SEARCH_URL=

# Минимальное количество отзывов аналога (фильтрация шумных карточек, см. ТЗ).
SAOL_MIN_FEEDBACKS=10

# Residential-proxy для запросов к WB (формат geonix.com: http://user:pass@host:{port})
PROXY_URL=
PROXY_PORTS=10000-10099

# SQLite база
SAOL_DB_PATH=./data/saol.db

# HTTP сервер
SAOL_HOST=0.0.0.0
SAOL_PORT=8088

# Допуски (см. ТЗ)
SAOL_RATING_GREEN=0.6
SAOL_RATING_YELLOW=0.3
SAOL_REQUEST_TIMEOUT_SECONDS=10
SAOL_SLOW_LOOKUP_MS=25000
SAOL_SNAPSHOT_MIN_INTERVAL_HOURS=6
SAOL_SNAPSHOT_MIN_DAYS_FOR_VELOCITY=1.0

# Откуда брать классификаторы при импорте
SAOL_CLASSIFIERS_DIR=./classifiers
